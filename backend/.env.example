# ---- Server ----
NODE_ENV=development
PORT=3001

# Long random string for signing short-lived access JWTs (15 min)
JWT_SECRET=change-me-to-a-long-random-string

# Comma-separated allowlist for CORS in production. In dev, "*" is used.
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGINS=*

# ---- WhatsApp Business Cloud API ----
# Graph API version is chosen here at project init (see plan). Bump quarterly.
WHATSAPP_API_VERSION=v21.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_APP_SECRET=

# Dev only: set true when testing via Chakra (no Meta signature header). Must be false in production.
WEBHOOK_SKIP_SIGNATURE=false

# DNS for WhatsApp media CDN (lookaside.fbsbx.com). Use if downloads fail with ENOENT/0.0.0.0.
WHATSAPP_MEDIA_DNS_SERVERS=8.8.8.8,1.1.1.1

# ---- Neon PostgreSQL ----
# Pooled connection string for the app
DATABASE_URL=
# Direct (non-pooled) connection string used only for migrations (optional;
# falls back to DATABASE_URL when unset)
DATABASE_URL_UNPOOLED=

# ---- AWS S3 ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=
# Apply 30-day lifecycle rule on media/ at startup (off by default for local dev).
S3_ENSURE_LIFECYCLE=false

# ---- Anthropic (AI agents) ----
ANTHROPIC_API_KEY=

# Fraction (0..1) of new conversations routed to the AI agent (deterministic bucketing)
AI_ROUTING_FRACTION=0.1
