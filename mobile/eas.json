{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "development",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "EXPO_PUBLIC_API_URL": "http://192.168.100.25:3001",
        "EXPO_PUBLIC_SOCKET_URL": "http://192.168.100.25:3001"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": { "simulator": false },
      "env": {
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "EXPO_PUBLIC_API_URL": "https://whatsapp-inbox-4wqd.onrender.com",
        "EXPO_PUBLIC_SOCKET_URL": "https://whatsapp-inbox-4wqd.onrender.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "distribution": "internal",
      "prebuildCommand": "npx expo prebuild --platform android --clean",
      "android": {
        "image": "latest",
        "buildType": "apk"
      },
      "env": {
        "APP_VARIANT": "production",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "EXPO_PUBLIC_API_URL": "https://whatsapp-inbox-4wqd.onrender.com",
        "EXPO_PUBLIC_SOCKET_URL": "https://whatsapp-inbox-4wqd.onrender.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
