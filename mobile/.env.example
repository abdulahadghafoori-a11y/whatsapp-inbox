# Public env vars are inlined at build time by Expo (EXPO_PUBLIC_ prefix).
# On a physical device, localhost is the phone — use your PC's LAN IP (ipconfig → IPv4).
# Must match the network shown in `npx expo start` (e.g. exp://192.168.0.251:8081).
EXPO_PUBLIC_API_URL=http://192.168.0.251:3001
EXPO_PUBLIC_SOCKET_URL=http://192.168.0.251:3001
