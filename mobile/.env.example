# Public env vars are inlined at bundle time by Expo (EXPO_PUBLIC_ prefix).
# Copy to .env and set YOUR PC's LAN IP (same Wi‑Fi as the phone):
#   cp .env.example .env
#
# Windows: ipconfig → IPv4 on your Wi‑Fi adapter (not VPN/virtual adapters).
# The IP in `npx expo start` (exp://192.168.x.x:8081) should be on the same subnet.
#
# After changing .env, restart Metro with a clean cache:
#   npx expo start -c
#
EXPO_PUBLIC_API_URL=http://YOUR_LAN_IP:3001
EXPO_PUBLIC_SOCKET_URL=http://YOUR_LAN_IP:3001

# Production / EAS builds: HTTPS only (release builds throw on http://).
# EXPO_PUBLIC_API_URL=https://api.yourdomain.com
# EXPO_PUBLIC_SOCKET_URL=https://api.yourdomain.com
# Run `eas init` and set a real extra.eas.projectId in app.json (not all zeros).

# Optional: Sentry DSN for mobile crash reporting. Leave empty to disable.
EXPO_PUBLIC_SENTRY_DSN=
