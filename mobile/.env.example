# Copy:  cp .env.example .env
# Restart Metro after edits:  npx expo start --dev-client -c
#
# USB (recommended on physical phone):
#   REACT_NATIVE_PACKAGER_HOSTNAME=127.0.0.1
#   EXPO_PUBLIC_API_URL=http://127.0.0.1:3001
#   EXPO_PUBLIC_SOCKET_URL=http://127.0.0.1:3001
#   Then:  npm run adb:reverse   (or npm run connect:android)
#
# Wi‑Fi only: use PC LAN IP (ipconfig) and run scripts/open-firewall.ps1 as Admin
#
REACT_NATIVE_PACKAGER_HOSTNAME=127.0.0.1
EXPO_PUBLIC_API_URL=http://127.0.0.1:3001
EXPO_PUBLIC_SOCKET_URL=http://127.0.0.1:3001

# Production / EAS builds: HTTPS only (release builds throw on http://).
# EXPO_PUBLIC_API_URL=https://api.yourdomain.com
# EXPO_PUBLIC_SOCKET_URL=https://api.yourdomain.com
# Run `eas init` and set a real extra.eas.projectId in app.json (not all zeros).

# Optional: Sentry DSN for mobile crash reporting. Leave empty to disable.
EXPO_PUBLIC_SENTRY_DSN=
